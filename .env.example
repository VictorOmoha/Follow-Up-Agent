# ─── App/API ───────────────────────────────────────────────
AGENT_API_PORT=8787
BOOKING_LINK=https://calendar.google.com/calendar/appointments/schedules/demo
OWNER_BOOKING_LINK=https://calendar.google.com/calendar/appointments/schedules/demo
VITE_API_BASE_URL=http://127.0.0.1:8787/api

# ─── API Authentication ────────────────────────────────────
# Set a shared secret to require AGENT_API_KEY header on all API requests.
# Leave empty to disable auth (development mode only).
AGENT_API_KEY=

# ─── Gemini AI ─────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Gmail OAuth ───────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://127.0.0.1:8787/api/inboxes/gmail/callback

# ─── Twilio SMS ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Twilio Voice (optional, for Call channel) ─────────────
TWILIO_VOICE_FROM=
TWILIO_VOICE_TWIML_URL=

# ─── SMTP Email (optional, fallback for Email channel) ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Firestore Persistence (optional) ──────────────────────
# Set AGENT_PERSISTENCE=firestore to enable Firestore backend
AGENT_PERSISTENCE=local
GOOGLE_APPLICATION_CREDENTIALS=
FIRESTORE_PROJECT_ID=