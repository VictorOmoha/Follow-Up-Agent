# --- App/API ---
AGENT_API_PORT=8787
BOOKING_LINK=https://calendar.google.com/calendar/appointments/schedules/demo
OWNER_BOOKING_LINK=https://calendar.google.com/calendar/appointments/schedules/demo
VITE_API_BASE_URL=

# --- API Authentication ---
# Set a shared secret to require AGENT_API_KEY header on all API requests.
# Leave empty to disable auth (development mode only).
AGENT_API_KEY=

# --- Webhook Authentication ---
# Set a separate key for webhook endpoints. Leave empty to allow open webhooks.
WEBHOOK_API_KEY=

# --- Gemini AI ---
GEMINI_API_KEY=

# --- Gmail OAuth ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# In production, set this to your Firebase Hosting URL:
# GMAIL_REDIRECT_URI=https://your-project.web.app/api/inboxes/gmail/callback
GMAIL_REDIRECT_URI=http://127.0.0.1:8787/api/inboxes/gmail/callback

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Twilio Voice (optional) ---
TWILIO_VOICE_FROM=
TWILIO_VOICE_TWIML_URL=

# --- SMTP Email (optional fallback) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Firestore Persistence ---
# In production (Cloud Functions), Firestore is auto-enabled.
# For local dev with Firestore, set AGENT_PERSISTENCE=firestore
# and provide a service account key.
AGENT_PERSISTENCE=local
GOOGLE_APPLICATION_CREDENTIALS=
FIRESTORE_PROJECT_ID=

# --- Production Deploy (Firebase) ---
# Set these in Firebase Secrets: firebase functions:secrets:set KEY
# GMAIL_REDIRECT_URI should be your deployed URL + /api/inboxes/gmail/callback
# VITE_API_BASE_URL should be empty for Firebase Hosting (uses rewrites)
